<?xml version="1.0" encoding="UTF-8"?>
<project name="banking_managementjava" default="compile" basedir=".">
  <property name="src.dir" value="src"/>
  <property name="build.dir" value="bin"/>
  <property name="classes.dir" value="${build.dir}"/>

  <target name="init">
    <mkdir dir="${classes.dir}"/>
  </target>

  <target name="clean">
    <delete dir="${build.dir}"/>
  </target>

  <target name="compile" depends="init">
    <javac srcdir="${src.dir}" destdir="${classes.dir}" includeantruntime="false" source="11" target="11" />
  </target>

  <target name="jar" depends="compile">
    <jar destfile="${build.dir}/banking_managementjava.jar" basedir="${classes.dir}"/>
  </target>
</project>
